#!/usr/bin/env bash
# wiki-kanban-report - Generate structured report from completed kanban tasks
# Usage: wiki-kanban-report

WIKI_DIR="$HOME/wiki"
KANBAN_FILE="$WIKI_DIR/kanban.md"
PROMPT="You are a documentation assistant. Format this completed task into a brief report entry. Extract: Task name, When completed, Result (what changed), Code changes (commits/files), Tools/Projects affected. Use bullet points. Be concise."

echo "📋 Kanban Completion Report"
echo "**Generated:** $(date '+%Y-%m-%d %H:%M')"
echo ""

if [ ! -f "$KANBAN_FILE" ]; then
    echo "Kanban file not found: $KANBAN_FILE"
    exit 1
fi

# Extract and process each DONE section
task_count=0
in_done=0
current_content=""

process_task() {
    local content="$1"
    if [ -z "$content" ]; then
        return
    fi

    task_count=$((task_count + 1))

    # Build JSON payload
    PAYLOAD=$(jq -n \
        --arg prompt "$PROMPT" \
        --arg content "$content" \
        '{
            model: "gemma4:e2b",
            messages: [
                {role: "system", content: $prompt},
                {role: "user", content: "Format this completed task:\n\n\($content)"}
            ],
            stream: false
        }')

    result=$(curl -s http://localhost:11434/api/chat -d "$PAYLOAD" | jq -r '.message.content')
    echo "$result"
    echo ""
}

# Parse kanban line by line
while IFS= read -r line; do
    # Check if line starts a DONE section
    if [[ "$line" =~ ^###.*✅.*DONE ]]; then
        # Process previous task if exists
        if [ -n "$current_content" ]; then
            process_task "$current_content"
        fi
        # Start new task
        current_content="$line"
        in_done=1
        continue
    fi

    # Check if we hit another section header (end of DONE section)
    if [[ "$line" =~ ^### ]] && [ "$in_done" -eq 1 ]; then
        # End current task
        if [ -n "$current_content" ]; then
            process_task "$current_content"
        fi
        current_content=""
        in_done=0
        continue
    fi

    # Accumulate content if in DONE section
    if [ "$in_done" -eq 1 ]; then
        current_content="$current_content"$'\n'"$line"
    fi

done < "$KANBAN_FILE"

# Process last task if file ended while in DONE section
if [ "$in_done" -eq 1 ] && [ -n "$current_content" ]; then
    process_task "$current_content"
fi

echo "---"
echo ""
echo "📊 Total completed tasks: $task_count"
